{"remainingRequest":"/home/luu-dai/vueworkspace/blog/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/luu-dai/vueworkspace/blog/src/components/CurriculumVitae.vue?vue&type=style&index=0&id=4730258a&scoped=true&lang=css&","dependencies":[{"path":"/home/luu-dai/vueworkspace/blog/src/components/CurriculumVitae.vue","mtime":1598501050651},{"path":"/home/luu-dai/vueworkspace/blog/node_modules/css-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/luu-dai/vueworkspace/blog/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":499162500000},{"path":"/home/luu-dai/vueworkspace/blog/node_modules/postcss-loader/src/index.js","mtime":499162500000},{"path":"/home/luu-dai/vueworkspace/blog/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/luu-dai/vueworkspace/blog/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["CurriculumVitae.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA8IA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"CurriculumVitae.vue","sourceRoot":"src/components","sourcesContent":["<template>\n  <div id='cv' class=\"shadow\">\n    <div id=\"mycv\">\n      <div class=\"header\">\n        <div class='img'>\n          <img src=\"@/assets/ava.png\" alt='my avatar' style=\"margin: 5px\">\n        </div>\n        <div class=\"space\"></div>\n        <div class='general-info'>\n          <h3><i class=\"fa fa-user\" aria-hidden=\"true\"></i> {{user.name}}</h3>\n          <h3><i class=\"fa fa-address-book\" aria-hidden=\"true\"></i> {{user.address}}</h3>\n          <h3><i class=\"fa fa-mobile\" aria-hidden=\"true\"></i> {{user.phone}}</h3>\n          <h3><i class=\"fa fa-envelope\" aria-hidden=\"true\"></i> {{user.email}}</h3>\n        </div>\n      </div>\n      <div class=\"body\">\n        <div class='objective'>\n          <h1>Objective</h1>\n          <hr>\n          <p>{{user.objective}}</p>\n        </div>\n        <div class='education'>\n          <h1>Education</h1>\n          <hr>\n          <ul>\n            <li>Date of graduation: {{user.education.dateGraduation}}</li>\n            <li>University: {{user.education.university}}</li>\n            <li>Major: {{user.education.major}}</li>\n            <li>gpa: {{user.education.gpa}}</li>\n          </ul>\n        </div>\n        <div class='working-experience'>\n          <h1>Working Experience</h1>\n          <hr>\n          <ul>\n            <li v-for=\"we in user.workingExperiences\" :key=\"we.duties\">\n              <p>\n                <span>{{we.position}}</span>\n                <span><b> {{we.company}}</b></span>\n              </p>\n              <p>Duties: {{we.duties}}</p>\n            </li>\n          </ul>\n        </div>\n        <div class='skills'>\n          <h1>Skills</h1>\n          <hr>\n          <ul>\n            <li>\n              <p>Technical skills:</p>\n              <p v-for=\"ts in user.tech_skills\" :key=\"ts.type\">\n                <span>{{ts.type | capitalize}}: </span>\n                <span>{{ts.name}}</span>\n              </p>\n            </li>\n            <li>\n              <p>Soft skills: </p>\n              <p v-for=\"ss in user.soft_skills\" :key=\"ss\">{{ss}}</p>\n            </li>\n          </ul>\n        </div>\n        <div class='projects'>\n          <h1>Project</h1>\n          <hr>\n          <ul>\n            <li v-for=\"project in user.projects\" :key=\"project.name\">\n              {{project.name}}\n              <ul>\n                <li>Duration: {{project.duration}}</li>\n                <li>Team size: {{project.team_size}}</li>\n                <li>Language: {{project.language}}</li>\n                <li>Framework: {{project.framework}}</li>\n                <li>Database: {{project.database}}</li>\n                <li>Function: {{project.function}}</li>\n                <li>Github: {{project.github}}</li>\n              </ul>\n            </li>\n          </ul>\n        </div>\n        <div class='awards-honor'>\n          <h1>Awards and honors</h1>\n          <hr>\n          <ul>\n            <li v-for=\"aah in user.awards_honors\" :key=\"aah\">{{aah}}</li>\n          </ul>\n        </div>\n        <div class='additional-info'>\n          <h1>Additional Infomation</h1>\n          <hr>\n          <ul>\n            <li v-for=\"info in user.additional_info\" :key=\"info.type\">\n              <p>{{info.type}}: {{info.description}}</p>\n            </li>\n          </ul>\n        </div>\n        <br>\n      </div>\n    </div>\n    <div class=\"button\">\n      <button type=\"button\" class=\"\" @click=\"exportPdf()\">Export pdf</button>\n    </div>\n  </div>\n</template>\n\n<script>\nimport user from '@/cv.js'\n\nimport { library } from '@fortawesome/fontawesome-svg-core'\nimport { faAddressBook, faUser, faMobile, faEnvelope } from '@fortawesome/free-solid-svg-icons'\n\nlibrary.add(faAddressBook, faUser, faMobile, faEnvelope)\nexport default {\n  data () {\n    return {\n      user: {}\n    }\n  },\n  created () {\n    this.user = user\n  },\n  methods: {\n    exportPdf () {\n      const doc = new jsPDF('p', 'pt', 'letter')\n      // const html = document.getElementById('mycv')\n      // doc.addHTML(html, () => {\n      //   doc.save(\"output.pdf\")\n      // })\n      doc.text(\"Hello world!\", 10, 10);\n      doc.save(\"a4.pdf\");\n    }\n  },\n  filters: {\n    capitalize: function (value) {\n      if (!value) return ''\n      value = value.toString()\n      return value.charAt(0).toUpperCase() + value.slice(1)\n    }\n  }\n}\n</script>\n\n<style scoped>\n#cv {\n  width: 80%  !important;\n  margin: 0 auto !important;\n  text-align: left !important;\n  background-color: #B9F2FF !important;\n}\n.shadow {\n  -webkit-box-shadow: 3px 3px 5px 6px rgb(158, 156, 156) !important;  /* Safari 3-4, iOS 4.0.2 - 4.2, Android 2.3+ */\n  -moz-box-shadow:    3px 3px 5px 6px rgb(158, 156, 156) !important;  /* Firefox 3.5 - 3.6 */\n  box-shadow:         3px 3px 5px 6px rgb(158, 156, 156) !important;  /* Opera 10.5, IE 9, Firefox 4+, Chrome 6+, iOS 5 */\n}\nh1 {\n  color: #0f52ba !important;\n  z-index: 1 !important;\n  margin-bottom: 0 !important;\n  margin-top: 20px;\n}\n.header {\n  color: white;\n  /* background-color: #143b77; */\n  background-image: url('../assets/ho_guom.gif');\n  /* filter: blur(8px);\n  -webkit-filter: blur(8px); */\n  background-position: center;\n  background-repeat: no-repeat;\n  background-size: cover;\n  display: inline-flex;\n  width: 100%;\n}\n.body {\n  width: 90%;\n  margin: 0 auto;\n}\n.img {\n  width: 20%;\n  display: inline-block;\n  text-align: center;\n  margin-left: 20px;\n  margin-top: 5px;\n}\n.space {\n  width: 40%;\n}\n.general-info {\n  width: 40%;\n  display: inline-block;\n  margin-top: 10px;\n}\n.img img {\n  width: 200px;\n  height: 200px;\n}\nhr {\n  margin-top: 0;\n  color: black;\n}\n</style>\n"]}]}