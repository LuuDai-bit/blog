{"remainingRequest":"/home/luu-dai/vueworkspace/blog/node_modules/babel-loader/lib/index.js!/home/luu-dai/vueworkspace/blog/node_modules/cache-loader/dist/cjs.js??ref--0-0!/home/luu-dai/vueworkspace/blog/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/luu-dai/vueworkspace/blog/src/components/CurriculumVitae.vue?vue&type=script&lang=js&","dependencies":[{"path":"/home/luu-dai/vueworkspace/blog/src/components/CurriculumVitae.vue","mtime":1598491319832},{"path":"/home/luu-dai/vueworkspace/blog/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/luu-dai/vueworkspace/blog/node_modules/babel-loader/lib/index.js","mtime":499162500000},{"path":"/home/luu-dai/vueworkspace/blog/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/luu-dai/vueworkspace/blog/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["CurriculumVitae.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAoGA,OAAA,IAAA,MAAA,SAAA;AACA,SAAA,MAAA,QAAA,mCAAA;AACA,eAAA;AACA,EAAA,IADA,kBACA;AACA,WAAA;AACA,MAAA,IAAA,EAAA;AADA,KAAA;AAGA,GALA;AAMA,EAAA,OANA,qBAMA;AACA,SAAA,IAAA,GAAA,IAAA;AACA,GARA;AASA,EAAA,QAAA,EAAA;AACA,IAAA,KADA,mBACA;AACA,aAAA,MAAA;AACA;AAHA,GATA;AAcA,EAAA,OAAA,EAAA;AACA,IAAA,UAAA,EAAA,oBAAA,KAAA,EAAA;AACA,UAAA,CAAA,KAAA,EAAA,OAAA,EAAA;AACA,MAAA,KAAA,GAAA,KAAA,CAAA,QAAA,EAAA;AACA,aAAA,KAAA,CAAA,MAAA,CAAA,CAAA,EAAA,WAAA,KAAA,KAAA,CAAA,KAAA,CAAA,CAAA,CAAA;AACA;AALA;AAdA,CAAA","sourcesContent":["<template>\n  <div id='cv' class=\"shadow\">\n    <div class=\"header\">\n      <div class='img'>\n        <img src=\"@/assets/logo.png\" alt='my avatar' style=\"margin: 5px\">\n      </div>\n      <div class=\"space\"></div>\n      <div class='general-info'>\n        <h2><font-awesome-icon icon=\"iuser\" />{{user.name}}</h2>\n        <h3>Address: {{user.address}}</h3>\n        <h3>Phone: {{user.phone}}</h3>\n        <h3>Email: {{user.email}}</h3>\n      </div>\n    </div>\n    <div class=\"body\">\n      <div class='objective'>\n        <h1>Objective</h1>\n        <hr>\n        <p>{{user.objective}}</p>\n      </div>\n      <div class='education'>\n        <h1>Education</h1>\n        <hr>\n        <ul>\n          <li>Date of graduation: {{user.education.dateGraduation}}</li>\n          <li>University: {{user.education.university}}</li>\n          <li>Major: {{user.education.major}}</li>\n          <li>gpa: {{user.education.gpa}}</li>\n        </ul>\n      </div>\n      <div class='working-experience'>\n        <h1>Working Experience</h1>\n        <hr>\n        <ul>\n          <li v-for=\"we in user.workingExperiences\" :key=\"we.duties\">\n            <p>\n              <span>{{we.position}}</span>\n              <span><b> {{we.company}}</b></span>\n            </p>\n            <p>Duties: {{we.duties}}</p>\n          </li>\n        </ul>\n      </div>\n      <div class='skills'>\n        <h1>Skills</h1>\n        <hr>\n        <ul>\n          <li>\n            <p>Technical skills:</p>\n            <p v-for=\"ts in user.tech_skills\" :key=\"ts.type\">\n              <span>{{ts.type | capitalize}}: </span>\n              <span>{{ts.name}}</span>\n            </p>\n          </li>\n          <li>\n            <p>Soft skills: </p>\n            <p v-for=\"ss in user.soft_skills\" :key=\"ss\">{{ss}}</p>\n          </li>\n        </ul>\n      </div>\n      <div class='projects'>\n        <h1>Project</h1>\n        <hr>\n        <ul>\n          <li v-for=\"project in user.projects\" :key=\"project.name\">\n            {{project.name}}\n            <ul>\n              <li>Duration: {{project.duration}}</li>\n              <li>Team size: {{project.team_size}}</li>\n              <li>Language: {{project.language}}</li>\n              <li>Framework: {{project.framework}}</li>\n              <li>Database: {{project.database}}</li>\n              <li>Function: {{project.function}}</li>\n              <li>Github: {{project.github}}</li>\n            </ul>\n          </li>\n        </ul>\n      </div>\n      <div class='awards-honor'>\n        <h1>Awards and honors</h1>\n        <hr>\n        <ul>\n          <li v-for=\"aah in user.awards_honors\" :key=\"aah\">{{aah}}</li>\n        </ul>\n      </div>\n      <div class='additional-info'>\n        <h1>Additional Infomation</h1>\n        <hr>\n        <ul>\n          <li v-for=\"info in user.additional_info\" :key=\"info.type\">\n            <p>{{info.type}}: {{info.description}}</p>\n          </li>\n        </ul>\n      </div>\n      <br>\n    </div>\n  </div>\n</template>\n\n<script>\nimport user from '@/cv.js'\nimport { faUser } from '@fortawesome/free-solid-svg-icons'\nexport default {\n  data () {\n    return {\n      user: {}\n    }\n  },\n  created () {\n    this.user = user\n  },\n  computed: {\n    iuser () {\n      return faUser\n    }\n  },\n  filters: {\n    capitalize: function (value) {\n      if (!value) return ''\n      value = value.toString()\n      return value.charAt(0).toUpperCase() + value.slice(1)\n    }\n  }\n}\n</script>\n\n<style scoped>\n#cv {\n  width: 80%;\n  margin: 0 auto;\n  text-align: left;\n  background-color: #B9F2FF;\n}\n.shadow {\n  -webkit-box-shadow: 3px 3px 5px 6px rgb(158, 156, 156);  /* Safari 3-4, iOS 4.0.2 - 4.2, Android 2.3+ */\n  -moz-box-shadow:    3px 3px 5px 6px rgb(158, 156, 156);  /* Firefox 3.5 - 3.6 */\n  box-shadow:         3px 3px 5px 6px rgb(158, 156, 156);  /* Opera 10.5, IE 9, Firefox 4+, Chrome 6+, iOS 5 */\n}\nh1 {\n  color: #0f52ba;\n  z-index: 1;\n  margin-bottom: 0;\n}\n.header {\n  color: white;\n  /* background-color: #143b77; */\n  background-image: url('../assets/ho_guom.gif');\n  filter: blur(8px);\n  -webkit-filter: blur(8px);\n  background-position: center;\n  background-repeat: no-repeat;\n  background-size: cover;\n  display: inline-flex;\n  width: 100%;\n}\n.header h1 {\n  color: white;\n}\n.body {\n  width: 90%;\n  margin: 0 auto;\n}\n.img {\n  width: 20%;\n  display: inline-block;\n  text-align: center;\n  margin-left: 20px;\n  margin-top: 5px;\n}\n.space {\n  width: 40%;\n}\n.general-info {\n  width: 40%;\n  display: inline-block;\n}\n.img img{\n  width: 200px;\n  height: 200px;\n}\n</style>\n"],"sourceRoot":"src/components"}]}