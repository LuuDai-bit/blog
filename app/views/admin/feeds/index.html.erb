<div class="container mt-5">
  <div class="row">
    <div class="col-12">
      <h1 class="mb-4">Feeds</h1>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-10 offset-lg-1" id="feeds">
      <%= render 'feeds', feeds: @feeds %>
    </div>
  </div>

  <div id="see_more_meta">
    <%= link_to '', admin_feeds_path(params[:page], params[:per]), {class: "d-none", id: "see_more_link"} %>
  </div>
</div>
