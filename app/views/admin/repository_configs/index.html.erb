<%= render partial: 'shared/breadcrumbs', locals: { sites: [{name: 'Repository Configs', url: '#'}] } %>

<h1 class="admin-title">Repository Configs</h1>
<div class="main-container">
  <% if @repositories.present? %>
    <table class="table table-hover table-layout-fixed w-100 mt-3 table-striped table-bordered">
      <thead>
        <tr>
          <th class="col-md-1 text-center">Id</th>
          <th class="col-md-3 text-center">Full Name</th>
          <th class="col-md-2 text-center">Action</th>
        </tr>
      </thead>
      <tbody id="admin-repositories">
        <%= render partial: 'repository', collection: @repositories %>
      </tbody>
    </table>
    <div id="admin-posts-paginate" class="pagination-admin d-flex justify-content-center">
      <%== pagy_bootstrap_nav(@pagy) %>
    </div>

  <% else %>
    <div class="mt-3 w-100 h-100vh text-center">
      NO REPOSITORIES
    </div>
  <% end %>
</div>
