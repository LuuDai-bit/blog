<tr class="align-middle">
  <td class="w-30"><span class="text-truncate-2l"><%= variable["id"] %></span></td>
  <td class="w-30"><span class="text-truncate-2l"><%= variable["name"] %></span></td>
  <td class="w-30"><span class="text-truncate-2l"><%= variable["format"] %></span></td>
  <td class="w-30">
    <button class="btn btn-light"
            title="Edit Variable"
            data-action="variable-modal#open"
            data-variable-id="<%= variable["id"] %>"
            data-variable-name="<%= variable["name"] %>"
            data-variable-format="<%= variable["format"] %>"
            data-variable-type="<%= variable["variable_type"] %>"
            data-bsm-input="<%= variable["boolean_success_message"] %>"
            data-bfm-input="<%= variable["boolean_false_message"] %>">
      <%= icon 'file', library: 'boxicons' %>
    </button>
    <button class="btn btn-danger"
            title="Delete Variable"
            data-action="variable-modal#delete"
            data-variable-id="<%= variable["id"] %>">
      <%= icon 'trash', library: 'boxicons' %>
    </button>
  </td>
</tr>
