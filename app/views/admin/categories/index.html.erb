<%= render partial: 'shared/breadcrumbs', locals: { sites: [{name: 'Categories', url: '#'}] } %>

<h1 class="admin-title">Categories</h1>
<div class="main-container">
  <% if @categories.present? %>
    <div class="row">
      <div class="col-12">
        <ul class="list-group">
          <% @categories.each do |category| %>
            <li class="list-group-item d-flex justify-content-between align-items-center">
              <div>
                <%= category.name %>
                <% if category.highlighted? %>
                  <span class="badge bg-warning text-dark ml-2">Highlighted (Order: <%= category.highlight_order %>)</span>
                <% end %>
              </div>
              <div>
                <%= link_to edit_admin_category_path(category), class: 'btn btn-light', title: 'Edit Category' do %>
                  <%= icon 'pencil', library: 'boxicons' %>
                <% end %>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
    <div id="admin-posts-paginate" class="pagination-admin d-flex justify-content-center mt-3">
      <%== pagy_bootstrap_nav(@pagy) %>
    </div>

  <% else %>
    <div class="mt-3 w-100 h-100vh text-center">
      NO CATEGORIES
    </div>
  <% end %>
</div>
